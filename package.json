{
  "name": "g1components",
  "version": "1.0.0",
  "description": "a custom weather component built with Lit",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "web components",
    "lit"
  ],
  "author": "Chauncey",
  "license": "ISC",
  "packageManager": "pnpm@10.4.1",
  "dependencies": {
    "lit": "^3.3.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/three": "^0.183.1",
    "terser": "^5.46.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4"
  }
}
